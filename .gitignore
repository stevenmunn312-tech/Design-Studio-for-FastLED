node_modules/
dist/
.vite/
.DS_Store
*.local

# Python upload helper (backend/) local state
backend/.venv/
backend/__pycache__/
backend/.helper-config.json   # persisted arduino-cli path
backend/bin/                  # self-installed arduino-cli binary
backend/.fbuild-project/      # fbuild build workspace + vendored FastLED lib
__pycache__/
*.pyc

# Local Claude Code agent/editor state (settings.local.json, launch.json) —
# but project skills are part of the repo's tooling and travel with it.
.claude/*
!.claude/skills/

# Saved node-graph patterns ("My Patterns") — per-user local content, written by
# the upload helper. Share individual pattern files by hand; don't commit the folder.
/My Patterns/

# scripts/freeform-shot.mjs timing log + raw/trimmed recordings — local
# working state for the demo rig, not curated assets. Committed screenshots
# in video-shots/ (e.g. *.png) are unaffected.
video-shots/timing-log.json
video-shots/*.mp4
video-shots/*.mkv
