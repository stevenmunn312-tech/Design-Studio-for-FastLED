node_modules/
dist/
.vite/
.desktop-build/
/release/
.DS_Store
*.local

# Scratch screenshots and session captures — never commit these
/artifacts/
/.tmp-live-*
/live-screen.png
/node-crop*.png

# Python upload helper (backend/) local state
backend/.venv/
backend/__pycache__/
# persisted arduino-cli path
backend/.helper-config.json
# self-installed arduino-cli binary
backend/bin/
# fbuild build workspace + vendored FastLED/audio libs
backend/.fbuild-project/
__pycache__/
*.pyc

# Local dev-server log dumps (vite stdout/stderr from the upload helper wrapper)
.codex-tmp/

# Local Claude Code agent/editor state (settings.local.json, launch.json) —
# but project skills are part of the repo's tooling and travel with it.
.claude/*
!.claude/skills/
# Scratch git worktrees Claude Code creates per-task; always local/disposable.
.claude/worktrees/

# Local skill cache mirroring .claude/skills/ for other tooling, plus its sync
# lockfile — regenerated locally, not repo content.
/.agents/
/skills-lock.json

# Saved node-graph patterns ("My Patterns") — per-user local content, written by
# the upload helper. Share individual pattern files by hand; don't commit the folder.
/My Patterns/

# Saved projects/workspaces — per-user local content generated by the app.
/Projects/
