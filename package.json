{
  "name": "fastled-studio",
  "private": true,
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node --disable-warning=DEP0040 ./node_modules/vite/bin/vite.js --host 127.0.0.1",
    "dev:named": "node --disable-warning=DEP0040 ./node_modules/vite/bin/vite.js --host 127.0.0.1 --open http://fastled-studio.localhost:5173",
    "build": "node --disable-warning=DEP0040 ./node_modules/typescript/bin/tsc -b && node --disable-warning=DEP0040 ./node_modules/vite/bin/vite.js build",
    "preview": "node --disable-warning=DEP0040 ./node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "preview:named": "node --disable-warning=DEP0040 ./node_modules/vite/bin/vite.js preview --host 127.0.0.1 --open http://fastled-studio.localhost:4173",
    "lint": "node --disable-warning=DEP0040 ./node_modules/eslint/bin/eslint.js .",
    "test": "node --disable-warning=DEP0040 ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node --disable-warning=DEP0040 ./node_modules/vitest/vitest.mjs",
    "test:coverage": "node --disable-warning=DEP0040 ./node_modules/vitest/vitest.mjs run --coverage",
    "package:desktop": "python desktop/build.py",
    "gen:node-cards": "esbuild scripts/generate-node-card-svgs.ts --bundle --platform=node --format=esm --define:import.meta.env.DEV=false --define:import.meta.env.VITEST=false --define:import.meta.env={} --outfile=node_modules/.cache/gen-node-cards.mjs --log-level=warning && node node_modules/.cache/gen-node-cards.mjs",
    "helper": "python -m uvicorn app:app --reload --port 8008 --app-dir backend"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.6",
    "essentia.js": "^0.1.3",
    "gifuct-js": "^2.1.2",
    "lz-string": "^1.5.0",
    "poline": "^0.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
