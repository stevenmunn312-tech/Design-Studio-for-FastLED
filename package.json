{
  "name": "fastled-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "helper": "python -m uvicorn app:app --reload --port 8008 --app-dir backend",
    "demo": "node scripts/record-demo.mjs",
    "demo:session": "node scripts/freeform-session.mjs",
    "demo:shot": "node scripts/freeform-shot.mjs",
    "demo:trim": "node scripts/trim-dead-sections.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.6",
    "essentia.js": "^0.1.3",
    "gifuct-js": "^2.1.2",
    "poline": "^0.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
